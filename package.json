{
  "name": "datei",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "build:dev": "ng build --configuration=development",
    "test": "ng test",
    "lint": "prettier --check . && ng lint",
    "format": "prettier --write . && ng lint --fix",
    "generate-openapi-bundle": "redocly bundle api/openapi.yaml -o dist/openapi.yaml",
    "generate-openapi-client": "rm -rf frontend/src/api && ng-openapi-gen --input dist/openapi.yaml --output frontend/src/api"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@angular/cdk": "~21.2.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.2.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "21.2.7",
    "@eslint/js": "^10.0.0",
    "@redocly/cli": "^2.19.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.58.2",
    "vitest": "^4.0.8"
  }
}

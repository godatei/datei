{
  "name": "datei",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "build:dev": "ng build --configuration=development",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch",
    "lint": "prettier --check . && ng lint",
    "format": "prettier --write . && ng lint --fix",
    "generate-openapi-bundle": "redocly bundle api/openapi.yaml -o dist/openapi.yaml",
    "generate-openapi-client": "rm -rf frontend/src/api && ng-openapi-gen --input dist/openapi.yaml --output frontend/src/api"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "26"
  },
  "dependencies": {
    "@angular/cdk": "~22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "@angular/material": "~22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "date-fns": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.0",
    "@redocly/cli": "^2.19.2",
    "@tailwindcss/postcss": "^4.2.4",
    "angular-eslint": "21.4.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.0",
    "ng-openapi-gen": "^1.0.5",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "^4.0.8"
  }
}

---
import {Image} from 'astro:assets';
import BaseLayout from '~/layouts/BaseLayout.astro';
import type {Post} from '~/types';
import {getSortedPosts} from '~/utils/blog';

export async function getStaticPaths() {
  const posts = await getSortedPosts();

  return posts.map(post => {
    return {
      params: {
        slug: post.data.slug + '/',
      },
      props: {
        post: post,
      },
    };
  });
}

export interface Props {
  post: Post;
}

const {post} = Astro.props;
const {Content} = await post.rendered;
---

<script>
  import '@material/web/chips/assist-chip.js';
  import '@material/web/chips/chip-set.js';
</script>

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
      <div class="meta">
        <ul class="authors">
          {
            post.data.authors.map(author => (
              <li>
                <Image
                  src={author.image}
                  alt={author.name}
                  width={40}
                  height={40}
                />
                <span>
                  <a
                    href={author.gitHub}
                    target="_blank"
                    rel="noopener noreferrer">
                    {author.name}
                  </a>
                  <small>{author.role}</small>
                </span>
              </li>
            ))
          }
        </ul>
        <time datetime={post.data.publishDate.toISOString()}>
          {
            post.data.publishDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
      </div>
      <Image
        class="cover"
        src={post.data.image}
        alt={post.data.title}
        width={1200}
      />
    </header>
    <Content />
    {
      post.data.tags.length > 0 && (
        <md-chip-set class="tags" aria-label="Tags">
          {post.data.tags.map(tag => (
            <md-assist-chip label={tag} />
          ))}
        </md-chip-set>
      )
    }
  </article>
</BaseLayout>

<style>
  article {
    max-width: 48rem;
    margin: 0 auto;
  }

  .description {
    font-size: 1.125rem;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .authors {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .authors li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .authors img {
    border-radius: 9999px;
  }

  .authors span {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .authors small {
    color: var(--md-sys-color-on-surface-variant);
  }

  .cover {
    border-radius: 1rem;
  }

  .tags {
    margin-top: 2.5rem;
  }
</style>

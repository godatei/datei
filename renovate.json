{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "postUpdateOptions": [
    "gomodTidy",
    "goGenerate",
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "matchSourceUrls": ["https://github.com/golangci/golangci-lint"],
      "groupName": "golangci-lint"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [".github/workflows/datei.yaml"],
      "matchStrings": [
        "\"(?<currentValue>[^\"]+)\",\\s+// renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)",
        "'(?<currentValue>[^']+)'\\s+# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)"
      ]
    }
  ]
}
